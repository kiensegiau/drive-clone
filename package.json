{
  "name": "drive-clone",
  "version": "1.0.0",
  "main": "src/index.js",
  "bin": "./src/index.js",
  "pkg": {
    "assets": [
      "node_modules/**/*",
      "config/**/*",
      "src/**/*",
      "node_modules/puppeteer/**/*",
      "node_modules/puppeteer-core/**/*"
    ],
    "scripts": [
      "src/**/*.js"
    ],
    "targets": ["node16-win-x64"],
    "outputPath": "dist"
  },
  "scripts": {
    "start": "node src/index.js",
    "build": "npm run clean && npm run prepare-pkg && pkg . --no-bytecode",
    "prepare": "node scripts/prepare-pkg.js",
    "clean": "rimraf dist .pkg-cache",
    "prepare-pkg": "node scripts/prepare-pkg.js",
    "postbuild": "node scripts/post-build.js"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "crypto": "^1.0.1",
    "ffprobe": "^1.1.2",
    "ffprobe-static": "^3.1.0",
    "firebase": "^11.0.2",
    "firebase-admin": "^13.0.1",
    "google-auth-library": "^8.9.0",
    "googleapis": "^105.0.0",
    "got": "^11.8.6",
    "javascript-obfuscator": "^4.1.1",
    "node-disk-info": "^1.3.0",
    "node-fetch": "^2.7.0",
    "pdfkit": "^0.13.0",
    "puppeteer": "^19.11.1",
    "puppeteer-core": "^23.8.0",
    "readline": "^1.3.0",
    "windows-drive-letters": "^4.0.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-reloader": "^1.2.3",
    "nodemon": "^2.0.20"
  },
  "pkg-externals": [
    "axios",
    "@firebase/webchannel-wrapper",
    "brotli",
    "typed-query-selector",
    "electron",
    "node-fs",
    "fs",
    "puppeteer",
    "puppeteer-core"
  ]
}
