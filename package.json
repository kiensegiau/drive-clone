{
  "name": "drive-clone",
  "version": "1.0.0",
  "main": "src/index.js",
  "bin": "src/index.js",
  "pkg": {
    "assets": [
      "src/**/*",
      "node_modules/**/*"
    ],
    "targets": [
      "node16-win-x64"
    ],
    "outputPath": "dist"
  },
  "scripts": {
    "start": "node src/index.js",
    "build": "pkg .",
    "postinstall": "npm rebuild"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "crypto": "^1.0.1",
    "ffprobe": "^1.1.2",
    "ffprobe-static": "^3.1.0",
    "firebase": "^11.0.2",
    "firebase-admin": "^13.0.1",
    "google-auth-library": "^8.9.0",
    "googleapis": "^105.0.0",
    "got": "^11.8.6",
    "javascript-obfuscator": "^4.1.1",
    "node-fetch": "^2.7.0",
    "pdfkit": "^0.13.0",
    "puppeteer": "^19.11.1",
    "puppeteer-core": "^23.8.0",
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-reloader": "^1.2.3",
    "nodemon": "^2.0.20"
  }
}
